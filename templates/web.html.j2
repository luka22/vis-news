<!DOCTYPE html>
<html lang="hr" data-lang="hr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Content-Security-Policy" content="
    default-src 'none';
    script-src 'unsafe-inline' https://www.windguru.cz;
    style-src 'unsafe-inline';
    img-src 'self' https://www.gradvis.hr https://static.windguru.cz https://www.windguru.cz data:;
    frame-src https://embed.windy.com;
    connect-src https://www.windguru.cz;
    font-src 'self';
    base-uri 'self';
    object-src 'none';
    form-action 'none';
  " />
  <title>Viške novosti / Vis Island News — issa.news</title>
  <link rel="icon" href="https://www.gradvis.hr/wp-content/uploads/2019/06/grb_vis.png" />
  <meta name="description" content="Dnevni pregled vijesti s otoka Visa. Daily news digest from Vis island, Croatia — local news, events, sea conditions." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="{{ site_url }}/" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="{{ site_url }}/" />
  <meta property="og:site_name"   content="issa.news" />
  <meta property="og:title"       content="Viške novosti / Vis Island News" />
  <meta property="og:description" content="Dnevni pregled vijesti s otoka Visa. Daily news digest from Vis island, Croatia." />
  <meta property="og:image"       content="https://www.gradvis.hr/wp-content/uploads/2019/06/grb_vis.png" />
  <meta name="language" content="hr, en" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Charter, 'Bitstream Charter', 'Sitka Text', Cambria, Georgia, serif;
      background: #fdf8f0;
      color: #2c2c2c;
      line-height: 1.75;
    }

    /* ── top accent ── */
    .flag-stripe {
      height: 3px;
      background: #D4002A;
    }

    /* ── language toggle ── */
    .lang-bar {
      background: #0f3050;
      display: flex;
      justify-content: flex-end;
      padding: 0.3rem 1rem;
      gap: 0.25rem;
    }
    .lang-btn {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.35);
      color: rgba(255,255,255,0.7);
      border-radius: 3px;
      padding: 0.15rem 0.6rem;
      font-family: sans-serif;
      font-size: 0.75rem;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: background 0.15s, color 0.15s;
    }
    .lang-btn.active {
      background: rgba(255,255,255,0.2);
      color: #fff;
      border-color: rgba(255,255,255,0.7);
    }
    .lang-btn:hover { background: rgba(255,255,255,0.15); color: #fff; }

    /* ── language visibility ── */
    [data-lang="hr"] .en { display: none; }
    [data-lang="en"] .hr { display: none; }

    /* ── header ── */
    header {
      background: #1a4a6b;
      color: #fff;
      padding: 1.5rem 1rem;
      text-align: center;
    }
    header .header-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
    }
    header img.grb {
      height: 72px;
      width: auto;
      filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));
    }
    header h1 { font-size: 1.9rem; letter-spacing: 0.04em; margin-bottom: 0.2rem; }
    header p  { font-size: 0.88rem; opacity: 0.75; }

    /* ── layout ── */
    .page {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1rem;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 2rem;
      align-items: start;
    }

    /* ── articles ── */
    .article {
      border-bottom: 1px solid #d9cebc;
      padding: 1.4rem 0.5rem;
      border-radius: 4px;
      transition: background 0.12s;
    }
    .article:hover { background: #f5f0e8; }
    .article:last-child { border-bottom: none; }

    .article-meta {
      font-size: 0.78rem;
      color: #7a6f5c;
      margin-bottom: 0.45rem;
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .source-badge {
      color: #fff;
      border-radius: 3px;
      padding: 0.1rem 0.45rem;
      font-size: 0.7rem;
      font-family: sans-serif;
      letter-spacing: 0.03em;
    }
    .article h2 { font-size: 1.1rem; margin-bottom: 0.45rem; line-height: 1.4; }
    .article h2 a { color: #1a4a6b; text-decoration: none; }
    .article h2 a:hover { text-decoration: underline; }
    .summary { font-size: 0.93rem; color: #3d3730; font-style: italic; }

    /* ── izdvajamo strip ── */
    .izdvajamo {
      background: #f0ebe0;
      border-top: 1px solid #d9cebc;
      border-bottom: 1px solid #d9cebc;
      padding: 1.25rem 1rem;
    }
    .izdvajamo-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .izdvajamo-label {
      font-family: sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #9a8e7c;
      margin-bottom: 0.85rem;
    }
    .izdvajamo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
    }
    .izdvajamo-card {
      background: #fff;
      border-radius: 5px;
      border: 1px solid #d9cebc;
      padding: 0.7rem 0.8rem;
      transition: box-shadow 0.12s;
    }
    .izdvajamo-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .izdvajamo-card .article-meta { margin-bottom: 0.3rem; }
    .izdvajamo-card h3 {
      font-size: 0.88rem;
      line-height: 1.35;
      margin-bottom: 0;
    }
    .izdvajamo-card h3 a { color: #1a4a6b; text-decoration: none; }
    .izdvajamo-card h3 a:hover { text-decoration: underline; }

    @media (max-width: 760px) {
      .izdvajamo-grid { grid-template-columns: 1fr; }
    }

    /* ── source badge colours ── */
    .badge-gradvis       { background: #1a4a6b; }
    .badge-vis-tourism   { background: #1a6b5a; }
    .badge-islandvis     { background: #b56a00; }
    .badge-nacional      { background: #8b1a1a; }
    .badge-slobodna      { background: #c0392b; }
    .badge-tz-komiza     { background: #2d6a2d; }
    .badge-index         { background: #5b2d8b; }
    .badge-dalmacijadanas{ background: #b54e00; }
    .badge-morski        { background: #0a5c8a; }
    .badge-tportal       { background: #e65c00; }
    .badge-jutarnji      { background: #b30000; }
    .badge-hrt           { background: #003d82; }
    .badge-n1            { background: #cc0000; }

    /* ── sidebar ── */
    .sidebar { position: sticky; top: 1rem; }

    .widget {
      background: #fff;
      border: 1px solid #d9cebc;
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 1.25rem;
    }
    .widget-title {
      background: #1a4a6b;
      color: #fff;
      font-family: sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.5rem 0.75rem;
    }
    .widget-body { padding: 0; }
    .widget-body iframe { display: block; width: 100%; border: none; }

    .stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.3rem 0.75rem;
      font-family: sans-serif;
      font-size: 0.83rem;
      border-bottom: 1px solid #f0ebe0;
    }
    .stat-row:last-child { border-bottom: none; }
    .stat-label { color: #7a6f5c; }
    .stat-value { font-weight: 600; color: #1a4a6b; }

    .widget-body a.wlink {
      display: block;
      padding: 0.6rem 0.75rem;
      font-family: sans-serif;
      font-size: 0.82rem;
      color: #1a4a6b;
      text-decoration: none;
      border-top: 1px solid #eee;
    }
    .widget-body a.wlink:first-child { border-top: none; }
    .widget-body a.wlink:hover { text-decoration: underline; }
    .widget-body a.ferry-link { background: #f5f0e8; line-height: 1.5; }

    /* ── footer ── */
    footer {
      text-align: center;
      padding: 2rem 1rem;
      font-size: 0.78rem;
      color: #9a8e7c;
      font-family: sans-serif;
    }

    /* ── mobile stats strip ── */
    .mobile-stats {
      display: none;
      background: #0f3050;
      padding: 0.4rem 0.5rem;
      justify-content: space-around;
      flex-wrap: wrap;
      gap: 0;
    }
    .mstat {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0.3rem 0.6rem;
    }
    .mstat-label {
      font-family: sans-serif;
      font-size: 0.62rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
    }
    .mstat-val {
      font-family: sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: #fff;
    }
    .mstat-divider {
      width: 100%;
      border-top: 1px solid rgba(255,255,255,0.12);
      margin: 0.1rem 0;
    }

    /* ── responsive ── */
    @media (max-width: 760px) {
      .page { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      header h1 { font-size: 1.4rem; }
      .mobile-stats { display: flex; }
      /* sea/sun stats shown in strip above — hide sidebar duplicates */
      .widget-sea, .widget-sun { display: none; }
      /* iframes are unusable at mobile width */
      .widget-windy, .widget-windguru { display: none; }
    }

    /* ── print ── */
    @media print {
      .flag-stripe, .lang-bar, .sidebar, footer { display: none; }
      .page { grid-template-columns: 1fr; }
      .article { break-inside: avoid; }
      .article h2 a { color: #000; }
      .article h2 a::after { content: " (" attr(href) ")"; font-size: 0.75rem; color: #666; }
      header { background: #fff; color: #000; }
      header img.grb { filter: none; }
    }
  </style>
</head>
<body>

<div class="flag-stripe"></div>

<!-- language bar -->
<div class="lang-bar">
  <button class="lang-btn active" onclick="setLang('hr')">HR</button>
  <button class="lang-btn" onclick="setLang('en')">EN</button>
</div>

<header>
  <div class="header-inner">
    <img class="grb"
         src="https://www.gradvis.hr/wp-content/uploads/2019/06/grb_vis.png"
         alt="Grb Grada Visa" />
    <div>
      <h1>
        <span class="hr">Viške novosti</span>
        <span class="en">Vis Island News</span>
      </h1>
      <p>
        <span class="hr">{{ article_count }} vijesti &mdash; ažurirano {{ generated_at.strftime('%d. %m. %Y.') }}</span>
        <span class="en">{{ article_count }} stories &mdash; updated {{ generated_at.strftime('%d %B %Y') }}</span>
      </p>
    </div>
    <img class="grb"
         src="https://www.gradvis.hr/wp-content/uploads/2019/06/grb_vis.png"
         alt="Grb Grada Visa" />
  </div>
</header>

<!-- mobile stats strip: key numbers below header, hidden on desktop -->
<div class="mobile-stats">
  {% if sidebar.sea %}
  <div class="mstat">
    <span class="mstat-label hr">Temp. mora</span>
    <span class="mstat-label en">Sea temp</span>
    <span class="mstat-val">{{ sidebar.sea.sea_temp }}&thinsp;°C</span>
  </div>
  <div class="mstat">
    <span class="mstat-label hr">Val</span>
    <span class="mstat-label en">Waves</span>
    <span class="mstat-val">{{ sidebar.sea.wave_height }}&thinsp;m</span>
  </div>
  {% endif %}
  {% if sidebar.sun %}
  <div class="mstat">
    <span class="mstat-label hr">Izlazak ☀️</span>
    <span class="mstat-label en">Sunrise ☀️</span>
    <span class="mstat-val">{{ sidebar.sun.sunrise }}</span>
  </div>
  <div class="mstat">
    <span class="mstat-label hr">Zalazak 🌅</span>
    <span class="mstat-label en">Sunset 🌅</span>
    <span class="mstat-val">{{ sidebar.sun.sunset }}</span>
  </div>
  {% endif %}
  {% if sidebar.sea or sidebar.wind %}
  <div class="mstat-divider"></div>
  {% if sidebar.sea and sidebar.sea.wave_direction %}
  <div class="mstat">
    <span class="mstat-label hr">Smjer vala</span>
    <span class="mstat-label en">Wave dir.</span>
    <span class="mstat-val">{{ sidebar.sea.wave_direction }}</span>
  </div>
  {% endif %}
  {% if sidebar.wind %}
  <div class="mstat">
    <span class="mstat-label hr">Vjetar</span>
    <span class="mstat-label en">Wind</span>
    <span class="mstat-val">{{ sidebar.wind.wind_speed_kn }}&thinsp;kn {{ sidebar.wind.wind_direction }}</span>
  </div>
  {% endif %}
  {% endif %}
</div>

{% set badge_class = {
  'gradvis.hr':          'badge-gradvis',
  'vis-tourism.com':     'badge-vis-tourism',
  'islandvis.blogspot.com': 'badge-islandvis',
  'nacional.hr':         'badge-nacional',
  'slobodnadalmacija.hr':'badge-slobodna',
  'tz-komiza.hr':        'badge-tz-komiza',
  'index.hr':            'badge-index',
  'dalmacijadanas.hr':   'badge-dalmacijadanas',
  'morski.hr':           'badge-morski',
  'tportal.hr':          'badge-tportal',
  'jutarnji.hr':         'badge-jutarnji',
  'hrt.hr':              'badge-hrt',
  'n1info.hr':           'badge-n1',
} %}

{% if featured %}
<div class="izdvajamo">
  <div class="izdvajamo-inner">
    <div class="izdvajamo-label">
      <span class="hr">Vis u medijima</span>
      <span class="en">Vis in the media</span>
    </div>
    <div class="izdvajamo-grid">
      {% for article in featured %}
      {% set date_dt = article.published or article.fetched_at %}
      <div class="izdvajamo-card">
        <div class="article-meta">
          <span class="source-badge {{ badge_class.get(article.source, 'badge-gradvis') }}">{{ article.source }}</span>
          {% if date_dt %}
          <span class="hr">{{ date_dt | reldate_hr }}</span>
          <span class="en">{{ date_dt | reldate_en }}</span>
          {% endif %}
        </div>
        <h3><a href="{{ article.url }}" target="_blank" rel="noopener">
          <span class="hr">{{ article.title }}</span>
          <span class="en">{{ article.title_en or article.title }}</span>
        </a></h3>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<div class="page">

  <!-- ── articles ── -->
  <main>
    {% if not articles %}
    <p style="text-align:center; padding:3rem 0; color:#9a8e7c;">
      <span class="hr">Nema novih vijesti ovaj tjedan.</span>
      <span class="en">No new articles this week.</span>
    </p>
    {% endif %}

    {% for article in articles %}
    <div class="article">
      <div class="article-meta">
        <span class="source-badge {{ badge_class.get(article.source, 'badge-gradvis') }}">{{ article.source }}</span>
        {% if article.published %}
        <span class="hr">{{ article.published | reldate_hr }}</span>
        <span class="en">{{ article.published | reldate_en }}</span>
        {% endif %}
      </div>
      <h2><a href="{{ article.url }}" target="_blank" rel="noopener">
        <span class="hr">{{ article.title }}</span>
        <span class="en">{{ article.title_en or article.title }}</span>
      </a></h2>
      {% if article.summary_hr %}
      <p class="summary hr">{{ article.summary_hr }}</p>
      {% endif %}
      {% if article.summary_en %}
      <p class="summary en">{{ article.summary_en }}</p>
      {% endif %}
    </div>
    {% endfor %}

  </main>

  <!-- ── sidebar ── -->
  <aside class="sidebar">

    <!-- Windy wind map -->
    <div class="widget widget-windy">
      <div class="widget-title">
        <span class="hr">🌬 Vjetar &amp; Vrijeme</span>
        <span class="en">🌬 Wind &amp; Weather</span>
      </div>
      <div class="widget-body">
        <iframe
          src="https://embed.windy.com/embed2.html?lat=43.06&lon=16.19&detailLat=43.06&detailLon=16.19&width=320&height=300&ptype=wind&type=map&location=coordinates&detail=true&metricWind=knots&metricTemp=%C2%B0C&radarRange=-1"
          height="300"
          loading="lazy"
          title="Windy – Vis"
        ></iframe>
      </div>
    </div>

    <!-- Sea conditions -->
    {% if sidebar.sea %}
    <div class="widget widget-sea">
      <div class="widget-title">
        <span class="hr">🌊 More — trenutno stanje</span>
        <span class="en">🌊 Sea Conditions</span>
      </div>
      <div class="widget-body" style="padding: 0.75rem 0;">
        <div class="stat-row">
          <span class="stat-label hr">Temperatura mora</span>
          <span class="stat-label en">Sea temperature</span>
          <span class="stat-value">{{ sidebar.sea.sea_temp }} °C</span>
        </div>
        <div class="stat-row">
          <span class="stat-label hr">Visina vala</span>
          <span class="stat-label en">Wave height</span>
          <span class="stat-value">{{ sidebar.sea.wave_height }} m</span>
        </div>
        <div class="stat-row">
          <span class="stat-label hr">Smjer vala</span>
          <span class="stat-label en">Wave direction</span>
          <span class="stat-value">{{ sidebar.sea.wave_direction }}</span>
        </div>
        <div class="stat-row">
          <span class="stat-label hr">Period vala</span>
          <span class="stat-label en">Wave period</span>
          <span class="stat-value">{{ sidebar.sea.wave_period }} s</span>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Sun times -->
    {% if sidebar.sun %}
    <div class="widget widget-sun">
      <div class="widget-title">
        <span class="hr">☀️ Sunce danas</span>
        <span class="en">☀️ Daylight</span>
      </div>
      <div class="widget-body" style="padding: 0.75rem 0;">
        <div class="stat-row">
          <span class="stat-label hr">Izlazak</span>
          <span class="stat-label en">Sunrise</span>
          <span class="stat-value">{{ sidebar.sun.sunrise }}</span>
        </div>
        <div class="stat-row">
          <span class="stat-label hr">Zalazak</span>
          <span class="stat-label en">Sunset</span>
          <span class="stat-value">{{ sidebar.sun.sunset }}</span>
        </div>
        <div class="stat-row">
          <span class="stat-label hr">Dan traje</span>
          <span class="stat-label en">Day length</span>
          <span class="stat-value">{{ sidebar.sun.day_length }}</span>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Windguru forecast -->
    <div class="widget widget-windguru">
      <div class="widget-title">📊 Windguru</div>
      <div class="widget-body" style="padding: 0.75rem;">
        <script type="text/javascript">
          var windguru_spot_id = "130826";
          var wg_width = "270";
          var wg_lang = "hr";
          var wg_show_stats = "1";
          var wg_models = "3";
        </script>
        <script type="text/javascript" src="https://www.windguru.cz/js/widget.php?uid=widget_130826"></script>
        <noscript>
          <a href="https://www.windguru.cz/130826" target="_blank" rel="noopener">Windguru – Vis</a>
        </noscript>
      </div>
      <a class="wlink" href="https://www.windguru.cz/130826" target="_blank" rel="noopener">
        <span class="hr">Otvori Windguru za Vis →</span>
        <span class="en">Open Windguru for Vis →</span>
      </a>
    </div>

    <!-- Links -->
    <div class="widget">
      <div class="widget-title">
        <span class="hr">🔗 Korisne poveznice</span>
        <span class="en">🔗 Useful Links</span>
      </div>
      <div class="widget-body">
        <a class="wlink ferry-link" href="https://www.jadrolinija.hr/hr/trajektne-linije/domace-linije/vis-split" target="_blank" rel="noopener">
          🚢 <strong><span class="hr">Red plovidbe Vis–Split</span><span class="en">Vis–Split Ferry</span></strong><br>
          <span style="font-size:0.75rem; opacity:0.75;"><span class="hr">Klikni za aktualni raspored →</span><span class="en">Click for live timetable →</span></span>
        </a>
        <a class="wlink" href="https://www.vis-tourism.com/hr/" target="_blank" rel="noopener"><span class="hr">TZ Vis – Turistička zajednica</span><span class="en">Vis Tourism Board</span></a>
        <a class="wlink" href="https://www.tz-komiza.hr/" target="_blank" rel="noopener"><span class="hr">TZ Komiža – Događanja</span><span class="en">Komiža Events</span></a>
        <a class="wlink" href="https://www.gradvis.hr/" target="_blank" rel="noopener"><span class="hr">Grad Vis – Službene stranice</span><span class="en">City of Vis – Official Site</span></a>
        <a class="wlink" href="https://www.windy.com/?43.060,16.190,12" target="_blank" rel="noopener"><span class="hr">Windy – Vis (detaljna karta)</span><span class="en">Windy – Vis (detailed map)</span></a>
      </div>
    </div>

  </aside>
</div>

<footer>
  <span class="hr">Generirano automatski &bull; Izvori: gradvis.hr, vis-tourism.com, tz-komiza.hr, islandvis.blogspot.com, slobodnadalmacija.hr, nacional.hr, index.hr, dalmacijadanas.hr</span>
  <span class="en">Auto-generated &bull; Sources: gradvis.hr, vis-tourism.com, tz-komiza.hr, islandvis.blogspot.com, slobodnadalmacija.hr, nacional.hr, index.hr, dalmacijadanas.hr</span>
</footer>

<script>
  // restore language before paint to avoid flash of wrong language
  (function() {
    const saved = localStorage.getItem('vis-lang') || 'hr';
    document.documentElement.setAttribute('data-lang', saved);
  })();

  function setLang(lang) {
    document.documentElement.setAttribute('data-lang', lang);
    localStorage.setItem('vis-lang', lang);
    document.documentElement.setAttribute('lang', lang);
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('active', btn.textContent === lang.toUpperCase());
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const saved = localStorage.getItem('vis-lang') || 'hr';
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('active', btn.textContent === saved.toUpperCase());
    });
  });
</script>

</body>
</html>
